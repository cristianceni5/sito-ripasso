{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build: E0b_compilation_example",
            "type": "shell",
            "command": "mkdir -p \"${workspaceFolder}/build\" && /usr/bin/clang++ -std=c++11 -Wall -Wextra -pedantic -g \"${workspaceFolder}/main.cpp\" \"${workspaceFolder}/greeter.cpp\" \"${workspaceFolder}/adder.cpp\" -o \"${workspaceFolder}/build/E0b_compilation_example\"",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Run: E0b_compilation_example",
            "type": "shell",
            "command": "\"${workspaceFolder}/build/E0b_compilation_example\"",
            "dependsOn": "Build: E0b_compilation_example",
            "problemMatcher": []
        },
        {
            "type": "cppbuild",
            "label": "C/C++: clang++ compila il file attivo",
            "command": "/usr/bin/clang++",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Attività generata dal debugger."
        }
    ]
}